<script setup lang="uts">
import { state } from '@/store/index.uts'

const props = defineProps({
  content: {
    type: String,
    default: ''
  }
})

const isDarkMode = computed(() => state.isDarkMode)
const expanded = ref(false)

const toggle = () => {
  expanded.value = !expanded.value
}
</script>

<template>
  <view class="page-intro" :class="isDarkMode ? 'theme-dark' : 'theme-light'" @click="toggle">
    <view class="page-intro-header">
      <text class="page-intro-label">页面介绍</text>
      <text class="page-intro-arrow">{{ expanded ? '▲' : '▼' }}</text>
    </view>
    <view v-if="expanded" class="page-intro-body">
      <text class="page-intro-content">{{ content }}</text>
    </view>
  </view>
</template>

