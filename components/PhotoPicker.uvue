<template>
  <view class="photo-picker">
    <view class="picker-area" @click="pickPhoto">
      <image v-if="photoPath" :src="photoPath" class="preview-image" />
      <view v-else class="empty-state">
        <text class="empty-icon">📷</text>
        <text class="empty-text">{{ hint }}</text>
      </view>
    </view>
    <text class="status-text" v-if="isUploading">上传�?..</text>
    <text class="status-text" v-else-if="isCompressing">压缩�?..</text>
  </view>
</template>

<script setup lang="uts">
import { ref } from 'vue'

const props = defineProps({
  hint: { type: String, default: '' }
})

const emit = defineEmits(['update'])

const photoPath = ref<string | null>(null)
const isUploading = ref<boolean>(false)
const isCompressing = ref<boolean>(false)

async function pickPhoto(): Promise<void> {
  uni.showActionSheet({
    itemList: ['拍照', '从相册选择'],
    success: async (res: any) => {
      const sourceType = res.tapIndex === 0 ? ['camera'] : ['album']
      uni.chooseImage({
        count: 1,
        sizeType: ['compressed'],
        sourceType: sourceType,
        success: async (imgRes: any) => {
          let path: string = imgRes.tempFilePaths[0] as string

          const fileInfo = await getFileInfoAsync(path)
          if ((fileInfo as any).size > 1024 * 1024) {
            isCompressing.value = true
            path = await compressImageAsync(path)
            isCompressing.value = false
          }

          photoPath.value = path

          // Try cloud upload
          let cloudURL: string | null = null
          try {
            isUploading.value = true
            const fs = uni.getFileSystemManager()
            const base64Data = fs.readFileSync(path, 'base64') as string
            const photoApi = uniCloud.importObject('photo-center')
            const uploadRes = await photoApi.upload({
              fileContent: base64Data,
              fileName: `photo_${Date.now()}.jpg`
            }) as UTSJSONObject
            const uploadData = uploadRes["data"] as UTSJSONObject
            cloudURL = uploadData["cloudURL"] as string
          } catch (e) {
            console.log('Photo upload failed', e)
          }
          isUploading.value = false

          emit('update', path, cloudURL)
        }
      })
    }
  })
}

function getFileInfoAsync(path: string): Promise<UTSJSONObject> {
  return new Promise((resolve) => {
    uni.getFileInfo({ filePath: path, success: (res: any) => resolve(res) })
  })
}

function compressImageAsync(path: string): Promise<string> {
  return new Promise((resolve) => {
    uni.compressImage({ src: path, quality: 80, success: (res: any) => resolve(res.tempFilePath) })
  })
}
</script>

<style>
.photo-picker {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.picker-area {
  width: 200rpx;
  height: 200rpx;
  border-radius: 100rpx;
  overflow: hidden;
  background-color: #f5f5f5;
  border: 3rpx dashed #cccccc;
  display: flex;
  align-items: center;
  justify-content: center;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-icon {
  font-size: 48rpx;
}

.empty-text {
  font-size: 20rpx;
  color: #999999;
  text-align: center;
}

.status-text {
  font-size: 22rpx;
  color: #f39c12;
  margin-top: 8rpx;
}
</style>
